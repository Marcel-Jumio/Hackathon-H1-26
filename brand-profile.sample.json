{
  "$schema": "./brand-profile.schema.json",
  "themeMode": "light",
  "brand": {
    "name": "Jumio",
    "sourceUrl": "https://www.jumio.com/",
    "logo": "https://www.jumio.com/wp-content/themes/understrap-child/images-dark-jumio/Jumio23-RGB%201.svg",
    "fontFamily": "Inter",
    "fontUrl": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap",
    "colors": {
      "primary": "#00D06A",
      "onPrimary": "#ffffff",
      "text": "#121214",
      "pageBackground": "#ffffff",
      "cardBackground": "#f7f8fa"
