    "logo": "https://documentation.jumio.ai/img/Jumio-Logo-color/Jumio23-RGB.svg",
    "fontFamily": "Inter",
    "fontUrl": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap",
    "colors": {
